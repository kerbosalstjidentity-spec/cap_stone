# 복사 후 .env 로 저장 (Git 제외)
LOG_LEVEL=info

# capstone train_export_rf 산출 joblib (절대·상대 경로)
MODEL_PATH=

# 대시보드가 읽을 metrics JSON 폴더 (metrics_open_val_holdout.json, monitor_open_test_full.json)
CAPSTONE_OUTPUTS_DIR=

# ── Kafka ──────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
# KAFKA_ENABLED=false    # true 시 consumer/producer 활성화

# ── Redis ─────────────────────────────────────────────
# PROFILE_STORE=redis    # memory(기본) or redis
REDIS_URL=redis://localhost:6379/0
PROFILE_TTL_SEC=604800  # 7일

# ── Firebase FCM ───────────────────────────────────────
# FIREBASE_ENABLED=true
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# ── API Key 인증 ────────────────────────────────────────
# API_KEY_ENABLED=true
# API_KEY=your-secret-key-here,another-key  # 쉼표로 여러 개

# ── Rate Limit ─────────────────────────────────────────
RATE_LIMIT_RPM=120
# RATE_LIMIT_ENABLED=false
