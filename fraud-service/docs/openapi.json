  "components": {
    "schemas": {
      "BatchScoreItem": {
        "properties": {
          "tx_id": {
            "type": "string",
            "title": "Tx Id"
          },
          "features": {
            "additionalProperties": true,
            "type": "object",
            "title": "Features"
          }
        },
        "type": "object",
        "required": [
          "tx_id"
        ],
        "title": "BatchScoreItem"
      },
      "BatchScoreRequest": {
        "properties": {
          "transactions": {
            "items": {
              "$ref": "#/components/schemas/BatchScoreItem"
            },
            "type": "array",
            "title": "Transactions"
          }
        },
        "type": "object",
        "required": [
          "transactions"
        ],
        "title": "BatchScoreRequest"
      },
      "BatchSimulateRequest": {
        "properties": {
          "scenarios": {
            "items": {
              "$ref": "#/components/schemas/SimulateScenario"
            },
            "type": "array",
            "title": "Scenarios"
          }
        },
        "type": "object",
        "required": [
          "scenarios"
        ],
        "title": "BatchSimulateRequest"
      },
      "FraudEvaluateRequest": {
        "properties": {
          "tx_id": {
            "type": "string",
            "title": "Tx Id",
            "description": "트랜잭션 ID"
          },
          "score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Score",
            "description": "모델 산출 확률"
          },
          "amount": {
            "type": "number",
            "minimum": 0.0,
            "title": "Amount",
            "description": "거래 금액 (원)"
          },
          "reason_code": {
            "type": "string",
            "title": "Reason Code",
            "description": "모델 reason_code (/v1/score 응답값)",
            "default": ""
          },
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "사용자 ID (Rule Engine 프로파일 조회용)",
            "default": ""
          },
          "hour": {
            "type": "integer",
            "maximum": 23.0,
            "minimum": -1.0,
            "title": "Hour",
            "description": "거래 시각 (0~23). -1=미지정",
            "default": -1
          },
          "is_foreign_ip": {
            "type": "boolean",
            "title": "Is Foreign Ip",
            "default": false
          },
          "ip": {
            "type": "string",
            "title": "Ip",
            "default": ""
          },
          "merchant_id": {
            "type": "string",
            "title": "Merchant Id",
            "default": ""
          },
          "device_id": {
            "type": "string",
            "title": "Device Id",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "tx_id",
          "score",
          "amount"
        ],
        "title": "FraudEvaluateRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IngestRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "tx_id": {
            "type": "string",
            "title": "Tx Id",
            "default": ""
          },
          "amount": {
            "type": "number",
            "minimum": 0.0,
            "title": "Amount"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          },
          "merchant_id": {
            "type": "string",
            "title": "Merchant Id",
            "default": ""
          },
          "device_id": {
            "type": "string",
            "title": "Device Id",
            "default": ""
          },
          "ip": {
            "type": "string",
            "title": "Ip",
            "default": ""
          },
          "is_foreign_ip": {
            "type": "boolean",
            "title": "Is Foreign Ip",
            "default": false
          },
          "hour": {
            "type": "integer",
            "maximum": 23.0,
            "minimum": -1.0,
            "title": "Hour",
            "default": -1
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "amount"
        ],
        "title": "IngestRequest"
      },
      "ScoreRequest": {
        "properties": {
          "features": {
            "additionalProperties": true,
            "type": "object",
            "title": "Features",
            "description": "V1..V30 키 (open 스키마). 없는 키는 0.0"
          }
        },
        "type": "object",
        "title": "ScoreRequest"
      },
      "SimulateRequest": {
        "properties": {
          "score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Score"
          },
          "amount": {
            "type": "number",
            "minimum": 0.0,
            "title": "Amount"
          },
          "user_id": {
            "type": "string",
            "title": "User Id",
            "default": ""
          },
          "hour": {
            "type": "integer",
            "maximum": 23.0,
            "minimum": -1.0,
            "title": "Hour",
            "default": -1
          },
          "is_foreign_ip": {
            "type": "boolean",
            "title": "Is Foreign Ip",
            "default": false
          },
          "ip": {
            "type": "string",
            "title": "Ip",
            "default": ""
          },
          "merchant_id": {
            "type": "string",
            "title": "Merchant Id",
            "default": ""
          },
          "device_id": {
            "type": "string",
            "title": "Device Id",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "score",
          "amount"
        ],
        "title": "SimulateRequest"
      },
      "SimulateScenario": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "score": {
            "type": "number",
