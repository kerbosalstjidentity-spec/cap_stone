    "/v1/simulate/threshold-sweep": {
      "get": {
        "tags": [
          "simulate"
        ],
        "summary": "Threshold Sweep",
        "description": "BLOCK_THRESHOLD를 0.5~0.99 범위로 바꿔가며 해당 score/amount 조합의 final_action 변화를 반환.",
        "operationId": "threshold_sweep_v1_simulate_threshold_sweep_get",
        "parameters": [
          {
            "name": "score",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.7,
              "title": "Score"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 500000,
              "title": "Amount"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
